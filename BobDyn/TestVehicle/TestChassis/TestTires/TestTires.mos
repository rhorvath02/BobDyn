// Set working directory to project root
cd("../../../../..");   // goes back from TestTires to repo root

// Load BobDyn package
loadModel(Modelica);   // base library
loadFile("BobDyn/package.mo");  

// Check that the package loads
getErrorString();

// Now load your test model
loadFile("BobDyn/TestVehicle/TestChassis/TestSuspension/TestTires/TestMF5p2Base.mo");

// Simulate the test model
simulate(BobDyn.TestVehicle.TestChassis.TestSuspension.TestTires.TestMF5p2Base, stopTime=5.0);

