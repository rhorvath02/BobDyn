setCommandLineOptions(
  "--simCodeTarget=C "
);

clear();
loadModel(Modelica);
loadFile("BobDyn/package.mo");

cd("Build/ISO4138");

res := buildModel(
    BobDyn.Standards.ISO4138,
    outputFormat="mat",
    numberOfIntervals=0,
    tolerance=1e-5,
    cflags="-O3 -march=native -mtune=native -ffast-math"
);